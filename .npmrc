public-hoist-pattern[]=h3
# vitepress build emits SSR temp .js files under docs/.vitepress/.temp/
# that `import 'vue'` directly. Node's ESM resolver walks parents from
# the temp file and only finds vue if it's hoisted to root node_modules.
# Without this hoist, `pnpm docs:build` fails with ERR_MODULE_NOT_FOUND
# during the deploy-docs-* GitHub Actions jobs.
public-hoist-pattern[]=vue
