{
  "name": "nuxt-edge-agentic-rag",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --dotenv .env -o",
    "prepare": "husky && nuxt prepare",
    "preview": "nuxt preview",
    "test": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "lint": "oxlint --deny-warnings .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm format && pnpm lint && pnpm typecheck && pnpm test",
    "typecheck": "nuxt typecheck",
    "setup": "bash scripts/setup.sh",
    "skills:install": "bash ./scripts/install-skills.sh",
    "skills:list": "bash ./scripts/check-skills.sh",
    "skills:update": "bash ./scripts/install-skills.sh",
    "spectra:roadmap": "npx tsx scripts/spectra-ux/roadmap-sync.mts",
    "audit:ux-drift": "npx tsx scripts/audit-ux-drift.mts"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxthub/core": "^0.10.7",
    "@onmax/nuxt-better-auth": "0.0.2-alpha.15",
    "@pinia/colada": "^1.0.0",
    "@pinia/colada-nuxt": "^0.3.2",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.43.0",
    "better-auth": "^1.5.5",
    "evlog": "^2.5.0",
    "nuxt": "^4.4.2",
    "nuxt-charts": "^2.1.3",
    "nuxt-security": "^2.5.1",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.72.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@iconify-json/lucide": "^1.2.97",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^14.2.1",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
}
