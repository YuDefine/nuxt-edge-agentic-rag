{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nuxt-edge-agentic-rag-staging",
  "compatibility_date": "2025-05-15",
  "vars": {
    "NUXT_KNOWLEDGE_D1_DATABASE": "DB",
    "NUXT_KNOWLEDGE_DOCUMENTS_BUCKET": "BLOB",
    "NUXT_KNOWLEDGE_RATE_LIMIT_KV": "KV",
    "NUXT_KNOWLEDGE_AI_SEARCH_INDEX": "agentic-rag-staging",
    "NUXT_KNOWLEDGE_ENVIRONMENT": "staging",
    "NUXT_KNOWLEDGE_FEATURE_PASSKEY": "true",
    "NUXT_PASSKEY_RP_ID": "yudefine.com.tw",
    "NUXT_PASSKEY_RP_NAME": "知識問答系統",
    "NUXT_KNOWLEDGE_AI_GATEWAY_ID": "agentic-rag-production",
    "NUXT_KNOWLEDGE_AI_GATEWAY_CACHE_ENABLED": "false",
    "CLOUDFLARE_ACCOUNT_ID": "0eac599c12df10586d97a78179b9f11f",
  },
  "routes": [
    {
      "pattern": "agentic-staging.yudefine.com.tw",
      "custom_domain": true,
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentic-rag-db-staging",
      "database_id": "d64077d7-b1c7-43f9-8dca-a1a1ff8c8350",
      "migrations_dir": "server/database/migrations",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "4cf276b2f754485da165ec47882599a9",
    },
  ],
  "ai": {
    "binding": "AI",
  },
  "r2_buckets": [
    {
      "binding": "BLOB",
      "bucket_name": "agentic-rag-documents-staging",
    },
  ],
  "triggers": {
    "crons": ["0 3 * * *"],
  },
}
