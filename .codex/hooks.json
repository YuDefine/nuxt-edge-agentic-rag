{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r '.tool_input.command' | grep -q '^git commit' && code-review-graph update 2>/dev/null || true",
            "statusMessage": "Updating code knowledge graph...",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/post-bash-error-debug.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/pre-commit-review.sh",
            "statusMessage": "Checking commit authorization...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/init-code-graph.sh",
            "statusMessage": "Initializing code knowledge graph...",
            "timeout": 120,
            "type": "command"
          },
          {
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/session-start-roadmap-sync.sh",
            "statusMessage": "Syncing Spectra roadmap...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/stop-accumulate.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
