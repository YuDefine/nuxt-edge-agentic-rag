{
  "$comment": "Auto-generated from .claude/settings.json hooks — Codex CLI format",
  "hooks": {
    "SessionStart": {
      "bash": {
        "command": ".claude/hooks/init-code-graph.sh && .claude/hooks/session-start-roadmap-sync.sh"
      }
    },
    "PreToolUse": {
      "$note": "Codex only intercepts Bash tool",
      "bash": {
        "command": ".claude/hooks/pre-commit-review.sh"
      }
    },
    "PostToolUse": {
      "$note": "Codex only intercepts Bash tool",
      "bash": {
        "command": ".claude/hooks/post-bash-error-debug.sh"
      }
    },
    "Stop": {
      "bash": {
        "command": ".claude/hooks/stop-accumulate.sh"
      }
    }
  }
}
