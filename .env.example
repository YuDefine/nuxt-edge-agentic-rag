# ============================================
# 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================

# --- Better Auth ---
# 必須至少 32 字元的隨機字串（openssl rand -base64 32）
BETTER_AUTH_SECRET=
# 必須至少 32 字元的隨機字串（openssl rand -base64 32）
NUXT_SESSION_PASSWORD=
# Google OAuth Client ID
NUXT_OAUTH_GOOGLE_CLIENT_ID=
# Google OAuth Client Secret
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
# GitHub OAuth Client ID
NUXT_OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth Client Secret
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# --- Knowledge Runtime ---
# local | staging | production
NUXT_KNOWLEDGE_ENVIRONMENT=local
# 以逗號分隔的管理員 email allowlist
ADMIN_EMAIL_ALLOWLIST=
# Workers bindings / deployment settings
NUXT_KNOWLEDGE_D1_DATABASE=
NUXT_KNOWLEDGE_DOCUMENTS_BUCKET=
NUXT_KNOWLEDGE_RATE_LIMIT_KV=
NUXT_KNOWLEDGE_AI_SEARCH_INDEX=
# R2 staged upload signing settings
NUXT_KNOWLEDGE_UPLOADS_ACCOUNT_ID=
NUXT_KNOWLEDGE_UPLOADS_BUCKET_NAME=
NUXT_KNOWLEDGE_UPLOADS_ACCESS_KEY_ID=
NUXT_KNOWLEDGE_UPLOADS_SECRET_ACCESS_KEY=
NUXT_KNOWLEDGE_UPLOADS_PRESIGN_EXPIRES_SECONDS=900
# Deferred feature flags（Production v1 預設關閉）
NUXT_KNOWLEDGE_FEATURE_PASSKEY=false
NUXT_KNOWLEDGE_FEATURE_MCP_SESSION=false
NUXT_KNOWLEDGE_FEATURE_CLOUD_FALLBACK=false
NUXT_KNOWLEDGE_FEATURE_ADMIN_DASHBOARD=false

# --- Sentry + Evlog ---
# Sentry DSN
NUXT_PUBLIC_SENTRY_DSN=
# Sentry Auth Token
SENTRY_AUTH_TOKEN=
# Sentry Organization
SENTRY_ORG=
# Sentry Project
SENTRY_PROJECT=
