# ============================================
# 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================

# --- Better Auth ---
# 必須至少 32 字元的隨機字串（openssl rand -base64 32）
BETTER_AUTH_SECRET=
# 必須至少 32 字元的隨機字串（openssl rand -base64 32）
NUXT_SESSION_PASSWORD=
# Google OAuth Client ID
NUXT_OAUTH_GOOGLE_CLIENT_ID=
# Google OAuth Client Secret
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# --- Passkey / WebAuthn ---
# 當 NUXT_KNOWLEDGE_FEATURE_PASSKEY=true 時必填。
# rpId 必須等於前端 origin 的 eTLD+1（local: localhost / prod: yourdomain.com）。
# rpName 會顯示在作業系統 passkey selector 的說明文字。
NUXT_PASSKEY_RP_ID=localhost
NUXT_PASSKEY_RP_NAME=知識問答系統

# --- Knowledge Runtime ---
# local | production
NUXT_KNOWLEDGE_ENVIRONMENT=local
# 以逗號分隔的管理員 email allowlist
ADMIN_EMAIL_ALLOWLIST=
# Workers bindings / deployment settings
NUXT_KNOWLEDGE_D1_DATABASE=DB
NUXT_KNOWLEDGE_DOCUMENTS_BUCKET=BLOB
NUXT_KNOWLEDGE_RATE_LIMIT_KV=KV
NUXT_KNOWLEDGE_AI_SEARCH_INDEX=
# R2 staged upload signing settings
NUXT_KNOWLEDGE_UPLOADS_ACCOUNT_ID=
NUXT_KNOWLEDGE_UPLOADS_BUCKET_NAME=
NUXT_KNOWLEDGE_UPLOADS_ACCESS_KEY_ID=
NUXT_KNOWLEDGE_UPLOADS_SECRET_ACCESS_KEY=
NUXT_KNOWLEDGE_UPLOADS_PRESIGN_EXPIRES_SECONDS=900
# Deferred feature flags（Production v1 預設關閉）
NUXT_KNOWLEDGE_FEATURE_PASSKEY=false
NUXT_KNOWLEDGE_FEATURE_MCP_SESSION=false
NUXT_KNOWLEDGE_FEATURE_CLOUD_FALLBACK=false
NUXT_KNOWLEDGE_FEATURE_ADMIN_DASHBOARD=false
# Remote MCP / Claude connector
# Claude remote connector callback（2026-04-24）:
# https://claude.ai/api/mcp/auth_callback
NUXT_KNOWLEDGE_MCP_ACCESS_TOKEN_TTL_SECONDS=600
NUXT_KNOWLEDGE_MCP_AUTHORIZATION_CODE_TTL_SECONDS=120
# Auth context signing secret for Nuxt -> Durable Object forwarding.
# production/staging 必設，且必須是 >= 32 bytes random；不可寫入 repo、logs、或錯誤訊息。
NUXT_MCP_AUTH_SIGNING_KEY=
# JSON array string. Example:
# [{"clientId":"claude-remote","enabled":true,"allowedScopes":["knowledge.ask","knowledge.search","knowledge.category.list","knowledge.citation.read"],"environments":["production"],"name":"Claude Remote","redirectUris":["https://claude.ai/api/mcp/auth_callback"]}]
NUXT_KNOWLEDGE_MCP_CONNECTOR_CLIENTS_JSON=[{"clientId":"claude-remote","enabled":true,"allowedScopes":["knowledge.ask","knowledge.search","knowledge.category.list","knowledge.citation.read"],"environments":["production"],"name":"Claude Remote","redirectUris":["https://claude.ai/api/mcp/auth_callback"]}]

# --- E2E / Playwright ---
# 本機 dev login 測試帳號，可依測試資料調整
E2E_BASE_URL=http://localhost:3010
E2E_ADMIN_EMAIL=admin@test.local
E2E_MEMBER_EMAIL=member@test.local
E2E_PASSWORD=testpass123
# --- AutoRAG API ---
NUXT_KNOWLEDGE_AUTO_RAG_API_TOKEN=

# --- AI Gateway ---
# Cloudflare AI Gateway instance id（Dashboard 建立的 gateway 名稱，例如 agentic-rag-production）。
# 留空則 chat / MCP 直連 Workers AI binding，不經 gateway 也不寫 log。
NUXT_KNOWLEDGE_AI_GATEWAY_ID=
# 是否啟用 gateway cache（true / false）。Default true。Admin 操作個別傳 skipCache=true。
NUXT_KNOWLEDGE_AI_GATEWAY_CACHE_ENABLED=true
# Cloudflare account id + read-only Analytics API token（/api/admin/usage 用）。
# Token scope：Account → Analytics → Read。NEVER 與部署 token 共用。
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN_ANALYTICS=


# --- MCP Tool-Selection Eval ---
# MCP tool-selection eval 使用；production runtime 不讀取。
# Eval 會呼叫 LLM API 產生成本；**NEVER** 把 pnpm eval 加入 pnpm check / test / CI gate。
# 完整前置與 staging / local 兩條路徑見 docs/evals/mcp-tool-selection.md。

# Anthropic API key（沿用 AI SDK / @ai-sdk/anthropic 慣例）。
# 取得：https://console.anthropic.com/ → API Keys。Pay-as-you-go，執行 pnpm eval 時才需要。
ANTHROPIC_API_KEY=

# MCP server URL。預設 http://localhost:3010/mcp（本專案 nuxt dev port）。
# 目前 @followup[TD-042] local NuxtHub KV binding 未 bridge → /mcp 回 503，
# 請暫時改指 staging：EVAL_MCP_URL=https://agentic-staging.yudefine.com.tw/mcp
# TD-042 解完後可切回 local。
EVAL_MCP_URL=http://localhost:3010/mcp

# Eval 連 MCP server 用的 Bearer token。取得方式：
# - Local（TD-042 解完後）：pnpm mint:dev-mcp-token，把 stdout 字串貼到等號後
# - Staging（目前預設）：在 staging /admin/tokens UI mint 30-day token
# Runtime 不讀取；local-only；NUXT_MCP_AUTH_SIGNING_KEY 輪替或 token 過期需重 mint。
EVAL_MCP_BEARER_TOKEN=

# Note: Eval 需 `NUXT_MCP_AUTH_SIGNING_KEY`（見上方 Remote MCP / Claude connector section）；
# 該 env 由 `wire-do-tool-dispatch` change 擁有，MCP middleware auth 必需。
