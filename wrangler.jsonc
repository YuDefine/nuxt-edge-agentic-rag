{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nuxt-edge-agentic-rag",
  "compatibility_date": "2025-05-15",
  "vars": {
    "NUXT_KNOWLEDGE_D1_DATABASE": "DB",
    "NUXT_KNOWLEDGE_DOCUMENTS_BUCKET": "BLOB",
    "NUXT_KNOWLEDGE_RATE_LIMIT_KV": "KV",
  },
  "routes": [{ "pattern": "agentic.yudefine.com.tw", "custom_domain": true }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentic-rag-db",
      "database_id": "3036df7f-d54b-4d36-a33d-ecbb551fc278",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "661ea98dad0743be86acc9ebeaf464f4",
    },
  ],
  "r2_buckets": [
    {
      "binding": "BLOB",
      "bucket_name": "agentic-rag-documents",
    },
  ],
}
