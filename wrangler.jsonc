{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nuxt-edge-agentic-rag",
  "compatibility_date": "2025-05-15",
  "vars": {
    "NUXT_KNOWLEDGE_D1_DATABASE": "DB",
    "NUXT_KNOWLEDGE_DOCUMENTS_BUCKET": "BLOB",
    "NUXT_KNOWLEDGE_RATE_LIMIT_KV": "KV",
    "NUXT_KNOWLEDGE_AI_SEARCH_INDEX": "agentic-rag",
    "NUXT_KNOWLEDGE_ENVIRONMENT": "production",
    "NUXT_KNOWLEDGE_FEATURE_PASSKEY": "true",
    "NUXT_KNOWLEDGE_FEATURE_MCP_SESSION": "true",
    "NUXT_PASSKEY_RP_ID": "yudefine.com.tw",
    "NUXT_PASSKEY_RP_NAME": "知識問答系統",
    "NUXT_KNOWLEDGE_AI_GATEWAY_ID": "agentic-rag-production",
    "NUXT_KNOWLEDGE_AI_GATEWAY_CACHE_ENABLED": "true",
    "CLOUDFLARE_ACCOUNT_ID": "0eac599c12df10586d97a78179b9f11f",
  },
  "routes": [{ "pattern": "agentic.yudefine.com.tw", "custom_domain": true }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentic-rag-db",
      "database_id": "3036df7f-d54b-4d36-a33d-ecbb551fc278",
      "migrations_dir": "server/database/migrations",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "661ea98dad0743be86acc9ebeaf464f4",
    },
  ],
  "ai": {
    "binding": "AI",
  },
  "r2_buckets": [
    {
      "binding": "BLOB",
      "bucket_name": "agentic-rag-documents",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_SESSION",
        "class_name": "MCPSessionDurableObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MCPSessionDurableObject"],
    },
  ],
  "triggers": {
    "crons": ["0 3 * * *"],
  },
}
